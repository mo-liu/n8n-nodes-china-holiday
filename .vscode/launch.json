{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "调试赛脑锁 (n8n 2.16.0)",
      "program": "${workspaceFolder}/node_modules/n8n/bin/n8n",
      "args": ["start"],
      "env": {
        "EXECUTIONS_PROCESS": "main",
        "N8N_CUSTOM_EXTENSIONS": "${workspaceFolder}/dist",
        "N8N_LOG_LEVEL": "debug"
      },
      "console": "integratedTerminal",
      "sourceMaps": true,
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}